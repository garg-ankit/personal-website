---
// Component Imports
import CallToAction from '../components/CallToAction.astro';
// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import Skills from '../components/Skills.astro';
// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

const differentiators = [
	{
		icon: 'heart',
		title: 'Supportive teammate',
		copy: 'Brings a consistently positive, approachable presence and makes time for the people around him.',
	},
	{
		icon: 'trophy',
		title: 'High standard of quality',
		copy: 'Contributes to delivery environments where reliability is expected, not treated as a nice surprise.',
	},
	{
		icon: 'strategy',
		title: 'Clear operator',
		copy: 'Helps teams move complex work forward through structure, coordination, and accountability.',
	},
	{
		icon: 'terminal-window',
		title: 'Strong ownership',
		copy: 'Shows integrity, self-motivation, and follow-through from planning through execution.',
	},
];

const recommendationHighlights = [
	'Praised for being approachable, generous with his time, and easy to work with.',
	'Recognized as a key contributor to a high-profile product that shipped for roughly 2.5 years without a critical bug or rollback.',
	'Trusted for bringing structure, clarity, and operational excellence to highly functional teams.',
];
---

<BaseLayout
	title="Ankit Garg | Lead QA Engineer"
	description="Lead QA Engineer focused on dependable execution, thoughtful coordination, and strong team culture."
>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Ankit Garg"
					tagline="Lead QA Engineer focused on dependable execution, thoughtful coordination, and the kind of team culture that helps ambitious work ship well."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="code" size="1.33em" /> QA Leadership</Pill>
						<Pill><Icon icon="trophy" size="1.33em" /> Delivery Excellence</Pill>
						<Pill><Icon icon="heart" size="1.33em" /> Team Builder</Pill>
					</div>
				</Hero>

				<aside class="hero-card stack gap-4">
					<p class="eyebrow">Recommendation Snapshot</p>
					<blockquote>
						“Approachable, always willing to help, and generous with his time.”
					</blockquote>
					<p class="highlight">
						On a high-profile product, his team shipped for roughly 2.5 years without a single
						critical bug or rollback.
					</p>
					<p class="supporting">
						That kind of reliability comes from discipline, ownership, and strong cross-team
						coordination.
					</p>
				</aside>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>What Teams Can Expect</h3>
					<p>
						This first pass focuses on the qualities that stand out most clearly in Ankit's track
						record and teammate feedback.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							differentiators.map(({ copy, icon, title }) => (
								<li class="value-card stack gap-3">
									<Icon icon={icon} color="var(--accent-regular)" size="2rem" gradient />
									<h4>{title}</h4>
									<p>{copy}</p>
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/about/">
						Read More
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Recommendation Highlights</h3>
					<p>
						Based on a recommendation from a former Vimeo teammate who worked closely with Ankit on
						a high-functioning product team.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						{
							recommendationHighlights.map((highlight) => (
								<li class="mention-card">
									<p>{highlight}</p>
								</li>
							))
						}
					</Grid>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero-card {
		width: 100%;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-md);
	}

	.eyebrow {
		font-size: var(--text-sm);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--gray-400);
	}

	blockquote {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		line-height: 1.3;
		color: var(--gray-0);
	}

	.highlight {
		color: var(--gray-200);
	}

	.supporting {
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
			align-items: center;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		min-height: 10rem;
		padding: 1.5rem;
		align-items: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.value-card {
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.value-card h4 {
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.value-card p {
		color: var(--gray-300);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			min-height: 12rem;
			padding: 2rem;
		}

		.value-card {
			padding: 2rem;
		}
	}
</style>
