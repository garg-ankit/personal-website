---
// Component Imports
import CallToAction from '../components/CallToAction.astro';
// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import Skills from '../components/Skills.astro';
// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

const focusAreas = [
	{
		icon: 'heart',
		title: 'Collaboration',
		copy: 'I try to be approachable, helpful, and easy to work with across teams.',
	},
	{
		icon: 'trophy',
		title: 'Quality',
		copy: 'I care about reliable releases, practical QA coverage, and steady follow-through.',
	},
	{
		icon: 'strategy',
		title: 'Coordination',
		copy: 'I like bringing structure to complex work without making the process heavier than it needs to be.',
	},
	{
		icon: 'terminal-window',
		title: 'Automation',
		copy: 'I use automation where it meaningfully improves confidence, speed, and repeatability.',
	},
];

const workingStyle = [
	'I value clear communication and realistic expectations.',
	'I try to help teams ship carefully and consistently.',
	'I care about calm collaboration when releases get complicated.',
];
---

<BaseLayout
	title="Ankit Garg | Lead QA Engineer"
	description="I work in QA across streaming products, with a focus on reliable releases, automation, and good collaboration."
>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Ankit Garg"
					tagline="I work in QA across streaming products, with a focus on reliable releases, practical automation, and good collaboration."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="code" size="1.33em" /> QA</Pill>
						<Pill><Icon icon="trophy" size="1.33em" /> Release Quality</Pill>
						<Pill><Icon icon="heart" size="1.33em" /> Collaboration</Pill>
					</div>
				</Hero>

				<aside class="hero-card stack gap-4">
					<p class="eyebrow">A Note From a Teammate</p>
					<blockquote>
						“Approachable, always willing to help, and generous with his time.”
					</blockquote>
					<p class="highlight">
						One part of my Vimeo work I am especially grateful for was being part of a team that
						went roughly two and a half years without a critical bug or rollback on a high-profile
						product.
					</p>
					<p class="supporting">
						I see that as a reflection of careful work, strong teamwork, and shared ownership.
					</p>
				</aside>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>How I Like to Work</h3>
					<p>
						A few themes shape how I approach QA, release work, and collaboration across teams.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							focusAreas.map(({ copy, icon, title }) => (
								<li class="value-card stack gap-3">
									<Icon icon={icon} color="var(--accent-regular)" size="2rem" gradient />
									<h4>{title}</h4>
									<p>{copy}</p>
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/about/">
						About Me
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<section class="section with-background bg-variant">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>What I Care About</h3>
					<p>
						These are the things I try to bring to the teams I work with.
					</p>
				</header>

				<div class="gallery">
					<Grid variant="small">
						{
							workingStyle.map((highlight) => (
								<li class="mention-card">
									<p>{highlight}</p>
								</li>
							))
						}
					</Grid>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero-card {
		width: 100%;
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-md);
	}

	.eyebrow {
		font-size: var(--text-sm);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--gray-400);
	}

	blockquote {
		margin: 0;
		font-family: var(--font-brand);
		font-size: var(--text-xl);
		line-height: 1.3;
		color: var(--gray-0);
	}

	.highlight {
		color: var(--gray-200);
	}

	.supporting {
		color: var(--gray-400);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
			align-items: center;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
		}
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		min-height: 10rem;
		padding: 1.5rem;
		align-items: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.value-card {
		padding: 1.5rem;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	.value-card h4 {
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.value-card p {
		color: var(--gray-300);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			min-height: 12rem;
			padding: 2rem;
		}

		.value-card {
			padding: 2rem;
		}
	}
</style>
